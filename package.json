{
  "name": "cachkit",
  "version": "0.2.1",
  "description": "High-performance caching and optimization layer for Node.js APIs.",
  "main": "lib/index.js",
  "bin": {
    "cachkit": "lib/cli.js"
  },
  "type": "module",
  "keywords": [
    "cache",
    "caching",
    "optimization",
    "performance",
    "nodejs",
    "api",
    "middleware",
    "redis",
    "memcached",
    "lru",
    "distributed-cache",
    "in-memory",
    "ttl",
    "redis-cache",
    "caching-library",
    "high-performance",
    "typescript"
  ],
  "author": "Corex Anthony <corexanthony24@gmail.com>",
  "license": "MIT",
  "files": [
    "lib/",
    "engine-requirement.js"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/Corex24/cachkit.git"
  },
  "homepage": "https://github.com/Corex24/cachkit#readme",
  "exports": {
    ".": {
      "import": "./lib/index.js",
      "require": "./lib/index.js"
    }
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "engineStrict": true,
  "scripts": {
    "build": "tsc -P tsconfig.build.json",
    "build:clean": "rimraf lib",
    "build:watch": "tsc -P tsconfig.build.json --watch",
    "build:all": "npm run build && npm run build:docs",
    "build:docs": "typedoc",
    "dev": "tsx watch ./src/index.ts",
    "start": "node lib/index.js",
    "lint": "eslint src --ext .ts,.js",
    "lint:fix": "npm run lint -- --fix",
    "format": "prettier --write \"src/**/*.{ts,js,json,md}\"",
    "typecheck": "tsc --noEmit",
    "test": "node --experimental-vm-modules node_modules/jest/bin/jest.js",
    "test:watch": "node --experimental-vm-modules node_modules/jest/bin/jest.js --watch",
    "test:coverage": "node --experimental-vm-modules node_modules/jest/bin/jest.js --coverage",
    "changelog": "conventional-changelog -p angular -i CHANGELOG.md -s",
    "changelog:preview": "conventional-changelog -p angular -u",
    "release": "release-it",
    "prepare": "npm run build",
    "prepack": "npm run build",
    "prepublishOnly": "npm run build",
    "preinstall": "node engine-requirement.js",
    "clean": "rimraf lib coverage",
    "docs:serve": "npx http-server docs",
    "deps:update": "npx npm-check-updates -u && npm install",
    "audit": "npm audit",
    "audit:fix": "npm audit fix"
  },
  "dependencies": {
    "ioredis": "^5.10.1",
    "lru-cache": "^11.2.7",
    "msgpack-lite": "^0.1.26",
    "pino": "^10.3.1"
  },
  "devDependencies": {
    "@jest/globals": "^30.3.0",
    "@types/jest": "^30.0.0",
    "@types/msgpack-lite": "^0.1.12",
    "@typescript-eslint/eslint-plugin": "^8.58.0",
    "@typescript-eslint/parser": "^8.58.0",
    "conventional-changelog-cli": "^5.0.0",
    "eslint": "^10.1.0",
    "npm-check-updates": "^19.6.6",
    "prettier": "^3.8.1",
    "release-it": "^19.2.4",
    "rimraf": "^6.1.3",
    "ts-jest": "^29.4.6",
    "tsx": "^4.21.0",
    "typedoc": "^0.28.18",
    "typescript": "^5.9.3"
  },
  "publishConfig": {
    "access": "public"
  }
}
